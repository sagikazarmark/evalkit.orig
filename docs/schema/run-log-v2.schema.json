{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://evalkit.dev/schema/run-log-v1.schema.json",
  "title": "evalkit Run Log v1",
  "description": "Schema catalog for evalkit JSONL run-log records and the aggregated RunResult structure.",
  "$comment": "Validate individual JSONL lines against the root schema. Validate an aggregated in-memory run result against #/$defs/RunResult.",
  "oneOf": [
    {
      "$ref": "#/$defs/HeaderRecord"
    },
    {
      "$ref": "#/$defs/MetadataRecord"
    },
    {
      "$ref": "#/$defs/SampleRecord"
    }
  ],
  "$defs": {
    "JsonValue": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/JsonValue"
          }
        },
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          }
        }
      ]
    },
    "Duration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "secs",
        "nanos"
      ],
      "properties": {
        "secs": {
          "type": "integer",
          "minimum": 0
        },
        "nanos": {
          "type": "integer",
          "minimum": 0,
          "maximum": 999999999
        }
      }
    },
    "Direction": {
      "type": "string",
      "enum": [
        "Maximize",
        "Minimize"
      ]
    },
    "ScoreDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "direction"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "direction": {
          "oneOf": [
            {
              "$ref": "#/$defs/Direction"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "TokenUsage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "input",
        "output",
        "cache_read",
        "cache_write"
      ],
      "properties": {
        "input": {
          "type": "integer",
          "minimum": 0
        },
        "output": {
          "type": "integer",
          "minimum": 0
        },
        "cache_read": {
          "type": "integer",
          "minimum": 0
        },
        "cache_write": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "Score": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "value"
          ],
          "properties": {
            "type": {
              "const": "numeric"
            },
            "value": {
              "type": "number"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "value"
          ],
          "properties": {
            "type": {
              "const": "binary"
            },
            "value": {
              "type": "boolean"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "value"
          ],
          "properties": {
            "type": {
              "const": "label"
            },
            "value": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "score",
            "reasoning",
            "metadata"
          ],
          "properties": {
            "type": {
              "const": "structured"
            },
            "score": {
              "type": "number"
            },
            "reasoning": {
              "type": "string"
            },
            "metadata": {
              "$ref": "#/$defs/JsonValue"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "name",
            "value",
            "unit"
          ],
          "properties": {
            "type": {
              "const": "metric"
            },
            "name": {
              "type": "string",
              "minLength": 1
            },
            "value": {
              "type": "number"
            },
            "unit": {
              "oneOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ]
            }
          }
        }
      ]
    },
    "ScoreResult": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "Ok"
          ],
          "properties": {
            "Ok": {
              "$ref": "#/$defs/Score"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "Err"
          ],
          "properties": {
            "Err": {
              "type": "string"
            }
          }
        }
      ]
    },
    "TrialResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scores",
        "duration",
        "trial_index"
      ],
      "properties": {
        "scores": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/ScoreResult"
          }
        },
        "duration": {
          "$ref": "#/$defs/Duration"
        },
        "trial_index": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "SampleResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sample_id",
        "trials",
        "trial_count",
        "scored_count",
        "error_count",
        "token_usage",
        "cost_usd"
      ],
      "properties": {
        "sample_id": {
          "type": "string",
          "minLength": 1
        },
        "trials": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/TrialResult"
          }
        },
        "trial_count": {
          "type": "integer",
          "minimum": 0
        },
        "scored_count": {
          "type": "integer",
          "minimum": 0
        },
        "error_count": {
          "type": "integer",
          "minimum": 0
        },
        "token_usage": {
          "$ref": "#/$defs/TokenUsage"
        },
        "cost_usd": {
          "oneOf": [
            {
              "type": "number",
              "minimum": 0
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "RunMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_id",
        "seed",
        "dataset_fingerprint",
        "scorer_fingerprint",
        "started_at",
        "completed_at",
        "duration",
        "trial_count",
        "score_definitions",
        "acquisition_mode"
      ],
      "properties": {
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "seed": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 0
            },
            {
              "type": "null"
            }
          ]
        },
        "dataset_fingerprint": {
          "type": "string",
          "minLength": 1
        },
        "scorer_fingerprint": {
          "type": "string",
          "minLength": 1
        },
        "code_commit": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "code_fingerprint": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "judge_model_pins": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "completed_at": {
          "type": "string",
          "format": "date-time"
        },
        "duration": {
          "$ref": "#/$defs/Duration"
        },
        "trial_count": {
          "type": "integer",
          "minimum": 0
        },
        "score_definitions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ScoreDefinition"
          }
        },
        "acquisition_mode": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "RunResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metadata",
        "samples"
      ],
      "properties": {
        "metadata": {
          "$ref": "#/$defs/RunMetadata"
        },
        "samples": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SampleResult"
          }
        }
      }
    },
    "HeaderRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_type",
        "schema_version"
      ],
      "properties": {
        "record_type": {
          "const": "header"
        },
        "schema_version": {
          "const": "1"
        }
      }
    },
    "MetadataRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_type",
        "metadata"
      ],
      "properties": {
        "record_type": {
          "const": "metadata"
        },
        "metadata": {
          "$ref": "#/$defs/RunMetadata"
        }
      }
    },
    "SampleRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_type",
        "sample"
      ],
      "properties": {
        "record_type": {
          "const": "sample"
        },
        "sample": {
          "$ref": "#/$defs/SampleResult"
        }
      }
    }
  }
}
